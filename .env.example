# [cl] 환경 변수 예시 파일
# 이 파일을 .env.local로 복사해서 실제 값을 넣으세요

# Cesium Ion 액세스 토큰 (https://ion.cesium.com/tokens)
NEXT_PUBLIC_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# Supabase 설정
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Gemini API (AI 큐레이션용)
# https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=your_gemini_api_key_here

# Wikidata 수집 정책 (optional)
# false로 두면 디테일이 없는 항목도 적재
WIKIDATA_REQUIRE_DETAIL=true
# true면 summary 없는 항목은 적재 제외
WIKIDATA_REQUIRE_SUMMARY=false
# 디테일 최소 점수(1~5 권장)
WIKIDATA_MIN_DETAIL_SCORE=1
